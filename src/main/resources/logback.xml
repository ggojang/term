<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_HOME" value="${user.home}/services/term/logs" />
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n" />

    <!-- 콘솔 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- app.log: 애플리케이션 전반 INFO, 7일/50MB rolling -->
    <appender name="APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/app-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <!-- fhir.log: FHIR 패키지 설치·CRUD INFO, 14일/20MB rolling -->
    <appender name="FHIR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/fhir.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/fhir-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <!-- error.log: ERROR만, 30일/10MB rolling -->
    <appender name="ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <!-- FHIR 패키지/리소스 로거 -->
    <logger name="co.infoclinic.term.fhir" level="INFO" additivity="false">
        <appender-ref ref="FHIR" />
        <appender-ref ref="ERROR" />
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- 애플리케이션 로거 (FHIR 제외) -->
    <logger name="co.infoclinic.term" level="INFO" additivity="false">
        <appender-ref ref="APP" />
        <appender-ref ref="ERROR" />
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- Spring/Hibernate: WARN만 -->
    <logger name="org.springframework" level="WARN" additivity="false">
        <appender-ref ref="APP" />
        <appender-ref ref="ERROR" />
    </logger>
    <logger name="org.hibernate" level="WARN" additivity="false">
        <appender-ref ref="APP" />
        <appender-ref ref="ERROR" />
    </logger>

    <!-- root -->
    <root level="WARN">
        <appender-ref ref="APP" />
        <appender-ref ref="ERROR" />
    </root>

</configuration>